# Makefile for managing local-first AI tools workspace

REPOS = $(shell ls -d */ | grep -v 'local-ai-tool-template/')

.PHONY: list test sync check fix verify status check-tools help-tools check-hooks show-coverage check-coverage stats usage pre-commit push unpushed help use-local use-github show-sources upgrade-locks check-standards check-installable

usage:
	@uv run pipeline-analysis/usage_stats.py

use-local:
	@python3 local-first-common/scripts/toggle_source.py local
	@$(MAKE) sync --no-print-directory

use-github:
	@python3 local-first-common/scripts/toggle_source.py github
	@$(MAKE) sync --no-print-directory

show-sources:
	@python3 local-first-common/scripts/toggle_source.py status

upgrade-locks:
	@echo "Upgrading local-first-common in all dependent repos..."
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ] && grep -q "local-first-common" "$$repo/pyproject.toml"; then \
			echo "  → $$repo"; \
			(cd $$repo && uv lock --upgrade-package local-first-common > /dev/null 2>&1); \
		fi \
	done
	@echo "Done. Run 'make sync' next."

check-standards:
	@echo "Checking for architectural violations..."
	@# Check: persona-counsel must NOT use resolve_provider
	@if [ -d "persona-counsel" ] && grep -r "resolve_provider" persona-counsel/src/ 2>/dev/null; then \
		echo "  [FAIL] persona-counsel is using resolve_provider! (Must use build_model)"; \
		exit 1; \
	fi
	@# Check: tool registration names must match repo names
	@echo "Verifying tool registration names..."
	@for repo in $(REPOS); do \
		if [ -d "$$repo/src" ]; then \
			case "$$repo" in "local-first-common/"|"local-first-mcp/"|"pebble/"|"local-ai-tool-template/") continue ;; esac; \
			repo_name=$$(basename "$$repo" | tr '-' '_'); \
			reg_name=$$(grep -r "register_tool(\"" "$$repo/src/" | head -1 | sed -E 's/.*register_tool\("([^"]+)".*/\1/'); \
			if [ -n "$$reg_name" ] && [ "$$reg_name" != "$$(basename "$$repo")" ]; then \
				echo "  [FAIL] $$repo registers as '$$reg_name' (expected '$$(basename "$$repo")')"; \
			fi \
		fi \
	done
	@# Check: register_tool must appear in exactly one file
	@echo "Checking for duplicate register_tool calls..."
	@for repo in $(REPOS); do \
		if [ -d "$$repo/src" ]; then \
			case "$$repo" in "local-first-common/"|"local-first-mcp/"|"pebble/"|"local-ai-tool-template/") continue ;; esac; \
			count=$$(grep -rl "register_tool(" "$$repo/src/" 2>/dev/null | wc -l | tr -d ' '); \
			if [ "$$count" -gt 1 ]; then \
				echo "  [FAIL] $$repo has register_tool() in $$count files (should be 1):"; \
				grep -rl "register_tool(" "$$repo/src/" | sed 's/^/    /'; \
			fi \
		fi \
	done
	@# Check: Typer anti-pattern (default value as first arg to typer.Option)
	@echo "Checking for Typer anti-patterns..."
	@for repo in $(REPOS); do \
		if [ -d "$$repo/src" ]; then \
			case "$$repo" in "local-first-common/"|"local-first-mcp/"|"pebble/"|"local-ai-tool-template/") continue ;; esac; \
			if grep -Ern "typer\.Option\(os\.environ|typer\.Option\(\"[^-]|typer\.Option\('[^-]" "$$repo/src/" 2>/dev/null | grep -v "\.pyc" > /dev/null; then \
				echo "  [FAIL] $$repo uses Typer anti-pattern (default value as first arg to typer.Option):"; \
				grep -Ern "typer\.Option\(os\.environ|typer\.Option\(\"[^-]|typer\.Option\('[^-]" "$$repo/src/" 2>/dev/null | sed 's/^/    /'; \
			fi \
		fi \
	done
	@# Check: direct LLM library usage outside of local-first-common
	@echo "Checking for direct LLM library imports..."
	@for repo in $(REPOS); do \
		if [ -d "$$repo/src" ]; then \
			case "$$repo" in "local-first-common/"|"local-first-mcp/"|"pebble/"|"local-ai-tool-template/") continue ;; esac; \
			if grep -Er "import anthropic|import openai|import google\.generativeai|import groq|import ollama|from anthropic|from openai|from google\.generativeai|from groq|from ollama" "$$repo/src/" > /dev/null; then \
				echo "  [FAIL] $$repo imports LLM libraries directly (must use local-first-common providers)"; \
			fi \
		fi \
	done
	@# Check: pydantic-ai usage outside of allowed repos
	@echo "Checking for pydantic-ai usage..."
	@for repo in $(REPOS); do \
		if [ -d "$$repo/src" ]; then \
			case "$$repo" in "local-first-common/"|"local-first-mcp/"|"pebble/"|"local-ai-tool-template/"|"persona-counsel/"|"marketing-persona-counsel/"|"pedantic-troll/") continue ;; esac; \
			if grep -r "pydantic_ai" "$$repo/src/" > /dev/null; then \
				echo "  [FAIL] $$repo uses pydantic_ai (only persona-counsel and marketing-persona-counsel are allowed)"; \
				grep -rl "pydantic_ai" "$$repo/src/" | sed 's/^/    /'; \
			fi \
		fi \
	done
	@# Check: timed_run usage (per-file: each file that calls .complete( must wrap it)
	@echo "Verifying timed_run coverage (CLI entry points)..."
	@for repo in $(REPOS); do \
		if [ -d "$$repo/src" ]; then \
			case "$$repo" in \
				"local-first-common/"|"local-first-mcp/"|"pebble/"|"local-ai-tool-template/") continue ;; \
			esac; \
			find "$$repo/src" -name "*.py" | while read pyfile; do \
				fname=$$(basename "$$pyfile"); \
				case "$$fname" in \
					logic.py|cli.py|main.py) \
						if grep -qE "\.acomplete\(|\.complete\(" "$$pyfile" 2>/dev/null; then \
							if ! grep -q "timed_run" "$$pyfile"; then \
								echo "  [FAIL] $$pyfile calls LLM but is missing timed_run"; \
							fi \
						fi \
						;; \
				esac; \
			done; \
		fi \
	done
	@# Check: Test isolation (must import isolate_tracking_db in conftest.py)
	@echo "Checking for test isolation (tracking DB)..."
	@for repo in $(REPOS); do \
		if [ -d "$$repo/tests" ]; then \
			case "$$repo" in "local-first-common/") continue ;; esac; \
			if [ ! -f "$$repo/tests/conftest.py" ]; then \
				echo "  [FAIL] $$repo is missing tests/conftest.py"; \
			elif ! grep -q "isolate_tracking_db" "$$repo/tests/conftest.py"; then \
				echo "  [FAIL] $$repo/tests/conftest.py is missing isolate_tracking_db import"; \
			fi \
		fi \
	done
	@# Check: Tests must NOT import providers directly (hitting real models)
	@echo "Verifying tests use MockProvider (no direct provider imports)..."
	@for repo in $(REPOS); do \
		if [ -d "$$repo/tests" ]; then \
			case "$$repo" in "local-first-common/") continue ;; esac; \
			if grep -Er "from local_first_common\.providers\.(ollama|anthropic|gemini|groq|deepseek) import" "$$repo/tests/" > /dev/null; then \
				echo "  [FAIL] $$repo/tests/ imports providers directly (must use MockProvider)"; \
				grep -Er "from local_first_common\.providers\.(ollama|anthropic|gemini|groq|deepseek) import" "$$repo/tests/" | sed 's/^/    /'; \
			fi \
		fi \
	done
	@# Check: Git hygiene (no junk/sensitive files tracked in index)
	@echo "Checking Git index hygiene..."
	@FORBIDDEN=".coverage .pytest_cache .ruff_cache .venv .DS_Store __pycache__ .env .envrc .cross-link-cache.db *.pyc *.pyo"; \
	for repo in $(REPOS); do \
		if [ -d "$$repo/.git" ]; then \
			for pattern in $$FORBIDDEN; do \
				tracked=$$(cd "$$repo" && git ls-files "$$pattern" 2>/dev/null); \
				if [ -n "$$tracked" ]; then \
					echo "  [FAIL] $$repo is tracking forbidden pattern: $$pattern"; \
				fi \
			done \
		fi \
	done
	@# Check: .gitignore coverage
	@echo "Verifying .gitignore coverage..."
	@REQUIRED=".coverage .pytest_cache .ruff_cache .venv .DS_Store __pycache__ .env .envrc"; \
	for repo in $(REPOS); do \
		case "$$repo" in "claude-skills/"|"local-ai-tool-template/") continue ;; esac; \
		if [ -d "$$repo" ]; then \
			if [ ! -f "$$repo/.gitignore" ]; then \
				echo "  [FAIL] $$repo is missing .gitignore"; \
			else \
				for pattern in $$REQUIRED; do \
					if ! grep -q "$$pattern" "$$repo/.gitignore"; then \
						echo "  [FAIL] $$repo/.gitignore is missing pattern: $$pattern"; \
					fi \
				done \
			fi \
		fi \
	done
	@echo "Standards check complete."

check-databases:
	@echo "Checking for databases stored locally in tool folders (should be in ~/sync)..."
	@for repo in $(REPOS); do \
		found=$$(find "$$repo" -maxdepth 2 -name "*.db" -o -name "*.sqlite" -o -name "*.duckdb" | grep -v ".venv/" | grep -v ".pytest_cache/"); \
		if [ -n "$$found" ]; then \
			echo "  [WARN] $$repo has local database(s):"; \
			echo "$$found" | sed 's/^/    /'; \
		fi \
	done

check-installable:
	@echo "Checking installability and documentation for all tools..."
	@PASS=0; FAIL=0; \
	for repo in $(REPOS); do \
		case "$$repo" in \
			"local-first-common/"|"claude-skills/"|"local-ai-tool-template/"|"pipeline-analysis/") continue ;; \
		esac; \
		if [ ! -f "$$repo/pyproject.toml" ]; then continue; fi; \
		repo_name=$$(basename "$$repo"); \
		echo "--- $$repo_name ---"; \
		REPO_PASS=1; \
		sync_out=$$(cd "$$repo" && uv sync --quiet 2>&1); \
		if [ $$? -eq 0 ]; then \
			echo "  [PASS] uv sync"; \
		else \
			echo "  [FAIL] uv sync: $$sync_out"; \
			REPO_PASS=0; \
		fi; \
		scripts_section=$$(grep -A5 '^\[project\.scripts\]' "$$repo/pyproject.toml" 2>/dev/null | grep -v '^\[project\.scripts\]' | grep -v '^$$' | grep -v '^\[' | head -1); \
		if [ -n "$$scripts_section" ]; then \
			echo "  [PASS] [project.scripts] present"; \
			cmd_name=$$(echo "$$scripts_section" | sed 's/[[:space:]]*=.*//' | tr -d ' '); \
			module_path=$$(echo "$$scripts_section" | sed 's/.*= *"\([^:]*\):.*/\1/' | tr -d ' '); \
			if [ -n "$$module_path" ]; then \
				import_out=$$(cd "$$repo" && uv run python -c "import $$module_path" 2>&1); \
				if [ $$? -eq 0 ]; then \
					echo "  [PASS] import $$module_path"; \
				else \
					echo "  [FAIL] import $$module_path: $$import_out"; \
					REPO_PASS=0; \
				fi; \
			fi; \
			if [ -f "$$repo/README.md" ]; then \
				echo "  [PASS] README.md exists"; \
				if grep -q "$$cmd_name" "$$repo/README.md" 2>/dev/null; then \
					echo "  [PASS] README.md documents entry point '$$cmd_name'"; \
				else \
					echo "  [FAIL] README.md does not mention entry point '$$cmd_name'"; \
					REPO_PASS=0; \
				fi; \
			else \
				echo "  [FAIL] README.md missing"; \
				REPO_PASS=0; \
			fi; \
		else \
			echo "  [FAIL] [project.scripts] missing in pyproject.toml"; \
			REPO_PASS=0; \
			if [ -f "$$repo/README.md" ]; then \
				echo "  [PASS] README.md exists"; \
			else \
				echo "  [FAIL] README.md missing"; \
			fi; \
		fi; \
		if [ "$$REPO_PASS" -eq 1 ]; then \
			PASS=$$((PASS + 1)); \
		else \
			FAIL=$$((FAIL + 1)); \
		fi; \
		echo ""; \
	done; \
	TOTAL=$$((PASS + FAIL)); \
	echo "$$PASS/$$TOTAL tools fully installable and documented"

check-scriptable:
	@echo "Checking for [project.scripts] in all tools..."
	@FAILED=0; \
	for repo in $(REPOS); do \
		case "$$repo" in \
			"local-first-common/"|"local-first-mcp/"|"local-ai-tool-template/"|"pipeline-analysis/"|"claude-skills/") continue ;; \
		esac; \
		if [ -f "$$repo/pyproject.toml" ]; then \
			if ! grep -q "^\[project\.scripts\]" "$$repo/pyproject.toml"; then \
				echo "  [FAIL] $$repo is missing [project.scripts]"; \
				FAILED=$$((FAILED + 1)); \
			fi; \
		fi; \
	done; \
	if [ $$FAILED -gt 0 ]; then \
		echo ""; \
		echo "✗ $$FAILED repo(s) are missing [project.scripts]. Run 'make fix-scriptable' to add defaults."; \
		exit 1; \
	else \
		echo "✓ All tools have entry points defined."; \
	fi

fix-scriptable:
	@echo "Adding default [project.scripts] to tools..."
	@for repo in $(REPOS); do \
		case "$$repo" in \
			"local-first-common/"|"local-first-mcp/"|"local-ai-tool-template/"|"pipeline-analysis/"|"claude-skills/") continue ;; \
		esac; \
		if [ -f "$$repo/pyproject.toml" ] && ! grep -q "^\[project\.scripts\]" "$$repo/pyproject.toml"; then \
			repo_name=$$(basename "$$repo"); \
			pkg_name=$$(echo "$$repo_name" | tr '-' '_'); \
			echo "  → Adding script '$$repo_name' to $$repo"; \
			printf "\n[project.scripts]\n$$repo_name = \"$$pkg_name.logic:app\"\n" >> "$$repo/pyproject.toml"; \
		fi; \
	done

help:
	@echo "Usage:"
	@echo "  make list          - List all tools in the workspace"
	@echo "  make sync          - Run 'uv sync' in all repositories"
	@echo "  make test          - Run 'uv run pytest' in all repositories"
	@echo "  make show-coverage - Show test coverage report for all repositories"
	@echo "  make check-coverage - Enforce 50% coverage threshold across repos (fails if any repo is under)"
	@echo "  make stats         - Show file length statistics and identify large files"
	@echo "  make check         - Run 'uv run ruff check' in all repositories"
	@echo "  make fix           - Run 'uv run ruff check --fix' in all repositories"
	@echo "  make status        - Show which repositories have uncommitted changes"
	@echo "  make uncommitted   - Show a concise list of repos with uncommitted work"
	@echo "  make unpushed      - Show which repositories have unpushed commits"
	@echo "  make check-tools   - Check that all tools follow the standardized structure"
	@echo "  make help-tools    - Show CLI help/parameters for all tools"
	@echo "  make check-hooks   - Check if git hooks are installed and up-to-date"
	@echo "  make check-standards - Verify architectural rules across all tools"
	@echo "  make check-installable - Validate every tool can be installed and has a documented entry point"
	@echo "  make check-scriptable  - Verify all tools have [project.scripts] entry points"
	@echo "  make fix-scriptable    - Add default entry points to tools that are missing them"
	@echo "  make check-databases   - Identify databases stored locally instead of in ~/sync"
	@echo "  make verify            - Full workspace health check (lint + tools + hooks + standards + coverage + installable + scriptable)"
	@echo "  make pre-commit    - Run all pre-commit checks (ruff, tests, security) for all tools"
	@echo "  make commit m=\"msg\" - Commit tracked changes across repositories with msg"
	@echo "  make push          - Push all repositories to their remotes (prompts for confirmation)"
	@echo "  make use-local     - Switch all repos to use local-first-common from ../local-first-common (dev mode)"
	@echo "  make use-github    - Switch all repos back to GitHub source (required before committing/pushing)"
	@echo "  make show-sources  - Show current local-first-common source for each repo"
	@echo "  make upgrade-locks - Upgrade local-first-common in all uv.lock files"

list:
	@echo "Local-first AI tools:"
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			desc=$$(grep '^description' "$$repo/pyproject.toml" 2>/dev/null | head -1 | cut -d'"' -f2); \
			printf "  %-42s %s\n" "$$repo" "$$desc"; \
		fi \
	done

sync:
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Syncing $$repo ---"; \
			(cd $$repo && uv sync); \
		fi \
	done

test:
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Testing $$repo ---"; \
			(cd $$repo && uv run pytest); \
		fi \
	done

show-coverage:
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Coverage: $$repo ---"; \
			(cd $$repo && uv run pytest --cov=src --cov-report=term-missing); \
		fi \
	done

check-coverage:
	@echo "Checking test coverage (minimum 50%) across repos..."
	@FAILED=0; \
	for repo in $(REPOS); do \
		case "$$repo" in \
			"local-first-common/"|"local-first-mcp/"|"local-ai-tool-template/") continue ;; \
		esac; \
		if [ -f "$$repo/pyproject.toml" ] && [ -d "$$repo/src" ]; then \
			echo "--- Coverage: $$repo ---"; \
			if ! (cd $$repo && uv run pytest --cov=src --cov-fail-under=50 -q 2>&1 | tail -8); then \
				FAILED=$$((FAILED + 1)); \
			fi; \
		fi \
	done; \
	if [ $$FAILED -gt 0 ]; then \
		echo ""; \
		echo "✗ $$FAILED repo(s) are below 50% coverage threshold."; \
		exit 1; \
	else \
		echo ""; \
		echo "✓ All repos meet coverage threshold."; \
	fi

stats:
	@echo "--- Top 10 Longest Python Files ---"
	@find . -name "*.py" -not -path "*/.venv/*" -not -path "*/__pycache__/*" -exec wc -l {} + | sort -rn | head -n 11
	@echo ""
	@echo "--- Files exceeding 400 lines (Refactor Candidates) ---"
	@find . -name "*.py" -not -path "*/.venv/*" -not -path "*/__pycache__/*" -exec wc -l {} + | awk '$$1 > 400 && $$2 != "total" {print $$0}' | sort -rn


check:
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Checking $$repo ---"; \
			(cd $$repo && uv run ruff check --extend-select SIM115 .); \
		fi \
	done

verify: check check-tools check-hooks check-standards check-coverage check-installable
	@echo ""
	@echo "✓ Full workspace verification complete."

fix:
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Fixing $$repo ---"; \
			(cd $$repo && uv run ruff check --extend-select SIM115 --fix .); \
		fi \
	done

status:
	@for repo in $(REPOS); do \
		if [ -d "$$repo/.git" ]; then \
			STATUS=$$(cd $$repo && git status --porcelain); \
			if [ -n "$$STATUS" ]; then \
				echo "--- $$repo ---"; \
				(cd $$repo && git status -s); \
				echo ""; \
			fi \
		fi \
	done

uncommitted:
	@echo "Repositories with uncommitted work:"
	@for repo in $(REPOS); do \
		if [ -d "$$repo/.git" ]; then \
			STATUS=$$(cd $$repo && git status --porcelain); \
			if [ -n "$$STATUS" ]; then \
				echo "  [ ] $$repo"; \
			fi \
		fi \
	done
	@echo ""

unpushed:
	@for repo in $(REPOS); do \
		if [ -d "$$repo/.git" ]; then \
			UPSTREAM=$$(cd $$repo && git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null); \
			if [ -n "$$UPSTREAM" ]; then \
				AHEAD=$$(cd $$repo && git rev-list --count @{u}..HEAD 2>/dev/null); \
				if [ "$$AHEAD" -gt 0 ] 2>/dev/null; then \
					echo "--- $$repo is ahead by $$AHEAD commits ---"; \
					(cd $$repo && git log @{u}..HEAD --oneline); \
					echo ""; \
				fi \
			else \
				echo "--- $$repo (no upstream tracking) ---"; \
			fi \
		fi \
	done

check-tools:
	@for repo in $(REPOS); do \
		case "$$repo" in \
			"local-first-common/"|"local-first-mcp/"|"pebble/"|"local-ai-tool-template/") continue ;; \
		esac; \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Checking $$repo ---"; \
			ERRORS=0; \
			if ! find "$$repo" -maxdepth 3 \( -name "logic.py" -o -name "cli.py" -o -name "main.py" \) | grep -q "."; then \
				echo "  ✗ Missing entry point (logic.py, cli.py, or main.py)"; \
				ERRORS=$$((ERRORS + 1)); \
			fi; \
			MAIN_FILE=$$(find "$$repo" -maxdepth 3 -name "main.py" | head -1); \
			if [ -n "$$MAIN_FILE" ]; then \
				if grep -q "Standard template for local-first AI tools" "$$MAIN_FILE"; then \
					echo "  ✗ main.py still contains boilerplate help text"; \
					ERRORS=$$((ERRORS + 1)); \
				fi; \
			fi; \
			if [ "$$ERRORS" -eq 0 ]; then \
				echo "  ✓ Structure looks good"; \
			fi; \
			echo ""; \
		fi \
	done

help-tools:
	@for repo in $(REPOS); do \
		case "$$repo" in \
			"local-first-common/"|"local-first-mcp/"|"pebble/"|"local-ai-tool-template/") continue ;; \
		esac; \
		MAIN_FILE=$$(find "$$repo" -maxdepth 3 -name "main.py" | head -1); \
		if [ -n "$$MAIN_FILE" ]; then \
			echo "--- Help: $$repo ---"; \
			MAIN_REL=$${MAIN_FILE#$$repo}; \
			(cd $$repo && uv run python .$$MAIN_REL --help); \
			echo ""; \
		fi \
	done

check-hooks:
	@HOOK_VERSION=$$(grep "HOOK_VERSION =" local-first-common/install_hooks.py | cut -d'"' -f2); \
	for repo in $(REPOS); do \
		if [ -d "$$repo/.git" ]; then \
			echo "--- Checking hooks: $$repo ---"; \
			for hook in pre-commit pre-push; do \
				if [ -f "$$repo/.git/hooks/$$hook" ]; then \
					if grep -q "Version: $$HOOK_VERSION" "$$repo/.git/hooks/$$hook"; then \
						echo "  ✓ $$hook is up to date (v$$HOOK_VERSION)"; \
					else \
						echo "  ✗ $$hook is OUTDATED or modified"; \
					fi; \
				else \
					echo "  ✗ $$hook is MISSING"; \
				fi; \
			done; \
			echo ""; \
		fi \
	done

pre-commit:
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Pre-commit: $$repo ---"; \
			(cd $$repo && \
			 uv run ruff check --extend-select SIM115 . && \
			 if [ -d "tests" ]; then uv run pytest -q; fi && \
			 python3 ../local-first-common/scripts/pre_push_check.py . --all-files); \
		fi \
	done

push:
	@read -p "Push all repos to GitHub? [Enter to continue, Ctrl-C to abort] " _
	@for repo in $(REPOS); do \
		if [ -d "$$repo/.git" ]; then \
			echo "--- Pushing $$repo ---"; \
			(cd $$repo && git push); \
		fi \
	done

commit:
	@if [ -z "$(m)" ]; then \
		echo "Error: Please provide a commit message with m=\"your message\""; \
		exit 1; \
	fi
	@for repo in $(REPOS); do \
		if [ -d "$$repo/.git" ]; then \
			STATUS=$$(cd $$repo && git status --porcelain); \
			if [ -n "$$STATUS" ]; then \
				echo "--- Committing in $$repo ---"; \
				(cd $$repo && git add -u && git commit -m "$(m)"); \
			fi \
		fi \
	done
