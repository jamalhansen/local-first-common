# Makefile for managing local-first AI tools workspace

REPOS = $(shell ls -d */ | grep -v 'local-ai-tool-template/')

.PHONY: list test sync check fix status verify-tools tool-help verify-hooks coverage stats usage pre-commit push check-pushed help use-local use-github source-status upgrade-locks check-standards

usage:
	@uv run pipeline-analysis/usage_stats.py

use-local:
	@python3 local-first-common/scripts/toggle_source.py local
	@$(MAKE) sync --no-print-directory

use-github:
	@python3 local-first-common/scripts/toggle_source.py github
	@$(MAKE) sync --no-print-directory

source-status:
	@python3 local-first-common/scripts/toggle_source.py status

upgrade-locks:
	@echo "Upgrading local-first-common in all dependent repos..."
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ] && grep -q "local-first-common" "$$repo/pyproject.toml"; then \
			echo "  → $$repo"; \
			(cd $$repo && uv lock --upgrade-package local-first-common > /dev/null 2>&1); \
		fi \
	done
	@echo "Done. Run 'make sync' next."

check-standards:
	@echo "Checking for architectural violations..."
	@# Check: persona-counsel must NOT use resolve_provider
	@if [ -d "persona-counsel" ] && grep -r "resolve_provider" persona-counsel/src/ 2>/dev/null; then \
		echo "  [FAIL] persona-counsel is using resolve_provider! (Must use build_model)"; \
		exit 1; \
	fi
	@# Check: timed_run usage (basic verify)
	@echo "Verifying timed_run coverage..."
	@for repo in $(REPOS); do \
		if [ -d "$$repo/src" ]; then \
			case "$$repo" in \
				"local-first-common/"|"local-first-mcp/"|"pebble/"|"local-ai-tool-template/") continue ;; \
			esac; \
			if grep -Er "PROVIDERS|pydantic_ai|BaseProvider|OllamaProvider" "$$repo/src/" > /dev/null; then \
				if ! grep -r "timed_run" "$$repo/src/" > /dev/null; then \
					echo "  [WARN] $$repo uses LLMs but might be missing timed_run tracking."; \
				fi \
			fi \
		fi \
	done
	@echo "Standards check complete."

help:
	@echo "Usage:"
	@echo "  make list    - List all tools in the workspace"
	@echo "  make sync    - Run 'uv sync' in all repositories"
	@echo "  make test    - Run 'uv run pytest' in all repositories"
	@echo "  make coverage - Show test coverage for all repositories"
	@echo "  make stats   - Show file length statistics and identify large files"
	@echo "  make check   - Run 'uv run ruff check' in all repositories"
	@echo "  make fix     - Run 'uv run ruff check --fix' in all repositories"
	@echo "  make status  - Show which repositories have uncommitted changes"
	@echo "  make uncommitted - Show a concise list of repos with uncommitted work"
	@echo "  make check-pushed - Show which repositories have unpushed commits"
	@echo "  make verify-tools - Check that all tools follow the standardized structure"
	@echo "  make tool-help - Show CLI help/parameters for all tools"
	@echo "  make verify-hooks - Check if git hooks are installed and up-to-date"
	@echo "  make pre-commit - Run all pre-commit checks (ruff, tests, security) for all tools"
	@echo "  make commit m=\"msg\" - Commit tracked changes across repositories with msg"
	@echo "  make push    - Push all repositories to their remotes (prompts for confirmation)"
	@echo "  make use-local     - Switch all repos to use local-first-common from ../local-first-common (dev mode)"
	@echo "  make use-github    - Switch all repos back to GitHub source (required before committing/pushing)"
	@echo "  make source-status - Show current local-first-common source for each repo"
	@echo "  make upgrade-locks - Upgrade local-first-common in all uv.lock files"
	@echo "  make check-standards - Verify architectural rules across all tools"

list:
	@echo "Local-first AI tools:"
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			desc=$$(grep '^description' "$$repo/pyproject.toml" 2>/dev/null | head -1 | cut -d'"' -f2); \
			printf "  %-42s %s\n" "$$repo" "$$desc"; \
		fi \
	done

sync:
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Syncing $$repo ---"; \
			(cd $$repo && uv sync); \
		fi \
	done

test:
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Testing $$repo ---"; \
			(cd $$repo && uv run pytest); \
		fi \
	done

coverage:
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Coverage: $$repo ---"; \
			(cd $$repo && uv run pytest --cov=src --cov-report=term-missing); \
		fi \
	done

stats:
	@echo "--- Top 10 Longest Python Files ---"
	@find . -name "*.py" -not -path "*/.venv/*" -not -path "*/__pycache__/*" -exec wc -l {} + | sort -rn | head -n 11
	@echo ""
	@echo "--- Files exceeding 400 lines (Refactor Candidates) ---"
	@find . -name "*.py" -not -path "*/.venv/*" -not -path "*/__pycache__/*" -exec wc -l {} + | awk '$$1 > 400 && $$2 != "total" {print $$0}' | sort -rn


check:
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Checking $$repo ---"; \
			(cd $$repo && uv run ruff check .); \
		fi \
	done

fix:
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Fixing $$repo ---"; \
			(cd $$repo && uv run ruff check --fix .); \
		fi \
	done

status:
	@for repo in $(REPOS); do \
		if [ -d "$$repo/.git" ]; then \
			STATUS=$$(cd $$repo && git status --porcelain); \
			if [ -n "$$STATUS" ]; then \
				echo "--- $$repo ---"; \
				(cd $$repo && git status -s); \
				echo ""; \
			fi \
		fi \
	done

uncommitted:
	@echo "Repositories with uncommitted work:"
	@for repo in $(REPOS); do \
		if [ -d "$$repo/.git" ]; then \
			STATUS=$$(cd $$repo && git status --porcelain); \
			if [ -n "$$STATUS" ]; then \
				echo "  [ ] $$repo"; \
			fi \
		fi \
	done
	@echo ""

check-pushed:
	@for repo in $(REPOS); do \
		if [ -d "$$repo/.git" ]; then \
			UPSTREAM=$$(cd $$repo && git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null); \
			if [ -n "$$UPSTREAM" ]; then \
				AHEAD=$$(cd $$repo && git rev-list --count @{u}..HEAD 2>/dev/null); \
				if [ "$$AHEAD" -gt 0 ] 2>/dev/null; then \
					echo "--- $$repo is ahead by $$AHEAD commits ---"; \
					(cd $$repo && git log @{u}..HEAD --oneline); \
					echo ""; \
				fi \
			else \
				echo "--- $$repo (no upstream tracking) ---"; \
			fi \
		fi \
	done

verify-tools:
	@for repo in $(REPOS); do \
		case "$$repo" in \
			"local-first-common/"|"local-first-mcp/"|"pebble/"|"local-ai-tool-template/") continue ;; \
		esac; \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Checking $$repo ---"; \
			ERRORS=0; \
			if [ ! -f "$$repo/src/main.py" ] && [ ! -f "$$repo/main.py" ]; then \
				echo "  ✗ Missing main.py (neither in root nor src/)"; \
				ERRORS=$$((ERRORS + 1)); \
			fi; \
			if [ ! -f "$$repo/src/logic.py" ] && [ ! -f "$$repo/logic.py" ] && ! find "$$repo/src" -name "logic.py" | grep -q "."; then \
				echo "  ✗ Missing logic.py (not in root, src/, or sub-packages)"; \
				ERRORS=$$((ERRORS + 1)); \
			fi; \
			MAIN_FILE=""; \
			if [ -f "$$repo/src/main.py" ]; then MAIN_FILE="$$repo/src/main.py"; \
			elif [ -f "$$repo/main.py" ]; then MAIN_FILE="$$repo/main.py"; fi; \
			if [ -n "$$MAIN_FILE" ]; then \
				if grep -q "Standard template for local-first AI tools" "$$MAIN_FILE"; then \
					echo "  ✗ main.py still contains boilerplate help text"; \
					ERRORS=$$((ERRORS + 1)); \
				fi; \
			fi; \
			if [ "$$ERRORS" -eq 0 ]; then \
				echo "  ✓ Structure looks good"; \
			fi; \
			echo ""; \
		fi \
	done

tool-help:
	@for repo in $(REPOS); do \
		case "$$repo" in \
			"local-first-common/"|"local-first-mcp/"|"pebble/"|"local-ai-tool-template/") continue ;; \
		esac; \
		MAIN_FILE=""; \
		if [ -f "$$repo/src/main.py" ]; then MAIN_FILE="src/main.py"; \
		elif [ -f "$$repo/main.py" ]; then MAIN_FILE="main.py"; fi; \
		if [ -n "$$MAIN_FILE" ]; then \
			echo "--- Help: $$repo ---"; \
			(cd $$repo && uv run python $$MAIN_FILE --help); \
			echo ""; \
		fi \
	done

verify-hooks:
	@HOOK_VERSION=$$(grep "HOOK_VERSION =" local-first-common/install_hooks.py | cut -d'"' -f2); \
	for repo in $(REPOS); do \
		if [ -d "$$repo/.git" ]; then \
			echo "--- Checking hooks: $$repo ---"; \
			for hook in pre-commit pre-push; do \
				if [ -f "$$repo/.git/hooks/$$hook" ]; then \
					if grep -q "Version: $$HOOK_VERSION" "$$repo/.git/hooks/$$hook"; then \
						echo "  ✓ $$hook is up to date (v$$HOOK_VERSION)"; \
					else \
						echo "  ✗ $$hook is OUTDATED or modified"; \
					fi; \
				else \
					echo "  ✗ $$hook is MISSING"; \
				fi; \
			done; \
			echo ""; \
		fi \
	done

pre-commit:
	@for repo in $(REPOS); do \
		if [ -f "$$repo/pyproject.toml" ]; then \
			echo "--- Pre-commit: $$repo ---"; \
			(cd $$repo && \
			 uv run ruff check . && \
			 if [ -d "tests" ]; then uv run pytest -q; fi && \
			 python3 ../local-first-common/scripts/pre_push_check.py . --all-files); \
		fi \
	done

push:
	@echo "WARNING: About to push ALL repositories to their remotes."
	@echo "Press Enter to continue or Ctrl-C to abort."
	@read -r _confirm; \
	for repo in $(REPOS); do \
		if [ -d "$$repo/.git" ]; then \
			echo "--- Pushing $$repo ---"; \
			(cd $$repo && git push); \
		fi \
	done

commit:
	@if [ -z "$(m)" ]; then \
		echo "Error: Please provide a commit message with m=\"your message\""; \
		exit 1; \
	fi
	@for repo in $(REPOS); do \
		if [ -d "$$repo/.git" ]; then \
			STATUS=$$(cd $$repo && git status --porcelain); \
			if [ -n "$$STATUS" ]; then \
				echo "--- Committing in $$repo ---"; \
				(cd $$repo && git add -u && git commit -m "$(m)"); \
			fi \
		fi \
	done
